{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nihongo-toastfish.local/schema/example-pack.schema.json",
  "title": "Nihongo ToastFish Grammar Example Pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["pack", "items"],
  "properties": {
    "pack": { "$ref": "#/$defs/packMetadata" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/grammarExample" }
    }
  },
  "$defs": {
    "jlptLevel": { "type": "string", "enum": ["N5", "N4", "N3", "N2", "N1"] },
    "questionType": {
      "type": "string",
      "enum": ["choose_sentence", "choose_meaning", "fill_pattern"]
    },
    "packMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packId", "version", "jlptLevel", "contentKind", "displayName", "source", "license"],
      "properties": {
        "packId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "jlptLevel": { "$ref": "#/$defs/jlptLevel" },
        "contentKind": { "const": "example" },
        "displayName": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "source": { "$ref": "#/$defs/source" },
        "license": { "$ref": "#/$defs/license" }
      }
    },
    "grammarExample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contentId", "sentenceJp", "meaningCn"],
      "properties": {
        "contentId": { "type": "string", "minLength": 1 },
        "grammarId": { "type": "string" },
        "sentenceJp": { "type": "string", "minLength": 1 },
        "sentenceKana": { "type": "string" },
        "sentenceFuriganaJson": { "type": "string" },
        "meaningCn": { "type": "string", "minLength": 1 },
        "questionType": { "$ref": "#/$defs/questionType" },
        "promptCn": { "type": "string" },
        "correctAnswer": { "type": "string" },
        "distractors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "name"],
      "properties": {
        "sourceId": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "attribution": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string" }
      }
    }
  }
}
