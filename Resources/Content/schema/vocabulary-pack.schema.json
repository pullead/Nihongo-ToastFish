{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nihongo-toastfish.local/schema/vocabulary-pack.schema.json",
  "title": "Nihongo ToastFish Vocabulary Pack",
  "type": "object",
  "additionalProperties": false,
  "required": ["pack", "items"],
  "properties": {
    "pack": { "$ref": "#/$defs/packMetadata" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/vocabularyItem" }
    }
  },
  "$defs": {
    "jlptLevel": { "type": "string", "enum": ["N5", "N4", "N3", "N2", "N1"] },
    "packMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packId", "version", "jlptLevel", "contentKind", "displayName", "source", "license"],
      "properties": {
        "packId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "jlptLevel": { "$ref": "#/$defs/jlptLevel" },
        "contentKind": { "const": "vocabulary" },
        "displayName": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "source": { "$ref": "#/$defs/source" },
        "license": { "$ref": "#/$defs/license" }
      }
    },
    "vocabularyItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contentId", "headword", "meaningCn"],
      "properties": {
        "contentId": { "type": "string", "minLength": 1 },
        "headword": { "type": "string", "minLength": 1 },
        "reading": { "type": "string" },
        "furiganaJson": { "type": "string" },
        "meaningCn": { "type": "string", "minLength": 1 },
        "partOfSpeech": { "type": "string" },
        "exampleJp": { "type": "string" },
        "exampleKana": { "type": "string" },
        "exampleFuriganaJson": { "type": "string" },
        "exampleCn": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "name"],
      "properties": {
        "sourceId": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "attribution": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string" }
      }
    }
  }
}
