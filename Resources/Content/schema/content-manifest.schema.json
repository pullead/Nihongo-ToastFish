{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nihongo-toastfish.local/schema/content-manifest.schema.json",
  "title": "Nihongo ToastFish Content Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifestVersion", "generatedAt", "packs"],
  "properties": {
    "manifestVersion": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "baseUrl": { "type": "string" },
    "packs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/packReference" }
    }
  },
  "$defs": {
    "jlptLevel": {
      "type": "string",
      "enum": ["gojuon", "N5", "N4", "N3", "N2", "N1"]
    },
    "contentKind": {
      "type": "string",
      "enum": ["gojuon", "vocabulary", "grammar", "example"]
    },
    "packReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packId",
        "version",
        "jlptLevel",
        "contentKind",
        "displayName",
        "path",
        "sha256",
        "source",
        "license"
      ],
      "properties": {
        "packId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "jlptLevel": { "$ref": "#/$defs/jlptLevel" },
        "contentKind": { "$ref": "#/$defs/contentKind" },
        "displayName": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
        "source": { "$ref": "#/$defs/source" },
        "license": { "$ref": "#/$defs/license" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "name"],
      "properties": {
        "sourceId": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "attribution": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string" }
      }
    }
  }
}
